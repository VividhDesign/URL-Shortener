## Create `client/app.js`

```javascript
// client/app.js

// IMPORTANT: Change this to your deployed backend URL when deploying!
const API_BASE = 'http://localhost:5000/api';

let currentShortCode = '';

async function shortenUrl() {
  const longUrl = document.getElementById('longUrlInput').value.trim();
  const expiresInDays = document.getElementById('expiryInput').value;

  // Reset UI
  document.getElementById('resultSection').style.display = 'none';
  document.getElementById('errorSection').style.display = 'none';
  document.getElementById('btnText').style.display = 'none';
  document.getElementById('btnLoader').style.display = 'inline';

  // Validate
  if (!longUrl) {
    showError('Please enter a URL');
    return;
  }

  try {
    const response = await fetch(`${API_BASE}/shorten`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        longUrl,
        expiresInDays: expiresInDays || undefined,
      }),
    });

    const data = await response.json();

    if (!response.ok) {
      showError(data.error || 'Something went wrong');
      return;
    }

    // Show result
    currentShortCode = data.shortCode;
    document.getElementById('shortUrlDisplay').href = data.shortUrl;
    document.getElementById('shortUrlDisplay').textContent = data.shortUrl;
    document.getElementById('analyticsLink').href = `analytics.html?code=${data.shortCode}`;
    document.getElementById('resultSection').style.display = 'block';

  } catch (error) {
    showError('Network error. Is the backend running?');
  } finally {
    document.getElementById('btnText').style.display = 'inline';
    document.getElementById('btnLoader').style.display = 'none';
  }
}

function showError(message) {
  document.getElementById('errorMessage').textContent = message;
  document.getElementById('errorSection').style.display = 'block';
  document.getElementById('btnText').style.display = 'inline';
  document.getElementById('btnLoader').style.display = 'none';
}

async function copyUrl() {
  const url = document.getElementById('shortUrlDisplay').textContent;
  await navigator.clipboard.writeText(url);
  const btn = document.querySelector('.copy-btn');
  btn.textContent = '✅ Copied!';
  setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
}
```

---

## Create `client/analytics.js`

```javascript
// client/analytics.js

const API_BASE = 'http://localhost:5000/api';

// Auto-load if code in URL params (e.g., analytics.html?code=aB3xYz)
window.onload = () => {
  const params = new URLSearchParams(window.location.search);
  const code = params.get('code');
  if (code) {
    document.getElementById('codeInput').value = code;
    loadAnalytics();
  }
};

async function loadAnalytics() {
  const code = document.getElementById('codeInput').value.trim();
  if (!code) return alert('Enter a short code');

  try {
    // Fetch all analytics in parallel
    const [summary, countries, devices] = await Promise.all([
      fetch(`${API_BASE}/analytics/${code}`).then(r => r.json()),
      fetch(`${API_BASE}/analytics/${code}/countries`).then(r => r.json()),
      fetch(`${API_BASE}/analytics/${code}/devices`).then(r => r.json()),
    ]);

    if (summary.error) return alert(summary.error);

    // Populate dashboard
    document.getElementById('totalClicks').textContent = summary.totalClicks;
    
    const daysActive = Math.floor(
      (new Date() - new Date(summary.createdAt)) / (1000 * 60 * 60 * 24)
    );
    document.getElementById('createdDays').textContent = daysActive;

    const originalLink = document.getElementById('originalUrl');
    originalLink.href = summary.longUrl;
    originalLink.textContent = summary.longUrl;

    // Render countries
    renderBars('countriesList', countries.data, 'country');
    
    // Render devices
    renderBars('devicesList', devices.data, 'device');

    document.getElementById('analyticsDashboard').style.display = 'block';

  } catch (err) {
    alert('Error loading analytics. Is the backend running?');
  }
}

function renderBars(containerId, data, labelKey) {
  const container = document.getElementById(containerId);
  if (!data || data.length === 0) {
    container.innerHTML = '<p style="color:#64748b;">No data yet</p>';
    return;
  }

  const max = data[0].count;
  container.innerHTML = data.map(item => `
    <div class="bar-row">
      <span class="bar-label">${item[labelKey] || 'Unknown'}</span>
      <div class="bar-track">
        <div class="bar-fill" style="width: ${(item.count / max) * 100}%"></div>
      </div>
      <span class="bar-count">${item.count}</span>
    </div>
  `).join('');
}
```


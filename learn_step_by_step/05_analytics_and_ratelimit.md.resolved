# 📊 Phase 4 — Analytics API + Phase 5 — Rate Limiting

> **Goal:** Build analytics endpoints and protect your API from abuse.
> **Time Estimate:** 2 hours
> **Skills Learned:** MongoDB aggregation pipeline, rate limiting, middleware

---

# PART A: Analytics API

## What Analytics Will We Build?

```
GET /api/analytics/:code              → Summary (total clicks, created date)
GET /api/analytics/:code/daily        → Clicks per day (last 30 days)
GET /api/analytics/:code/countries    → Top countries
GET /api/analytics/:code/devices      → Device breakdown (mobile/desktop/tablet)
GET /api/analytics/:code/referrers    → Top referrer sources
```

---

## Step 1: Analytics Controller

Create `server/controllers/analytics.controller.js`:

```javascript
// server/controllers/analytics.controller.js

const Analytics = require('../models/Analytics');
const Url = require('../models/Url');

// ─────────────────────────────────────────────────────────
// GET /api/analytics/:code
// Returns summary stats for a short URL
// ─────────────────────────────────────────────────────────
const getAnalyticsSummary = async (req, res) => {
  const { code } = req.params;

  try {
    // Check URL exists
    const urlDoc = await Url.findOne({ shortCode: code });
    if (!urlDoc) {
      return res.status(404).json({ error: 'Short URL not found' });
    }

    // Count total analytics records for this code
    const totalClicks = await Analytics.countDocuments({ shortCode: code });

    // Get first and last click times
    const firstClick = await Analytics.findOne({ shortCode: code }).sort({ createdAt: 1 });
    const lastClick = await Analytics.findOne({ shortCode: code }).sort({ createdAt: -1 });

    return res.status(200).json({
      shortCode: code,
      shortUrl: urlDoc.shortUrl,
      longUrl: urlDoc.longUrl,
      totalClicks,
      createdAt: urlDoc.createdAt,
      expiresAt: urlDoc.expiresAt,
      firstClickAt: firstClick?.createdAt || null,
      lastClickAt: lastClick?.createdAt || null,
    });

  } catch (error) {
    console.error('Analytics summary error:', error);
    return res.status(500).json({ error: 'Server error' });
  }
};

// ─────────────────────────────────────────────────────────
// GET /api/analytics/:code/daily
// Returns clicks grouped by day for last 30 days
// ─────────────────────────────────────────────────────────
const getDailyAnalytics = async (req, res) => {
  const { code } = req.params;

  // Get date 30 days ago
  const thirtyDaysAgo = new Date();
  thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

  try {
    // AGGREGATION PIPELINE — MongoDB's most powerful feature
    // Think of it like a series of steps/filters applied one after another
    const dailyData = await Analytics.aggregate([
      
      // STAGE 1: $match — filter documents (like WHERE in SQL)
      // Only include analytics for this shortCode AND from last 30 days
      {
        $match: {
          shortCode: code,
          createdAt: { $gte: thirtyDaysAgo }
        }
      },

      // STAGE 2: $group — group documents together (like GROUP BY in SQL)
      // Group by date (day), count how many documents in each group
      {
        $group: {
          // _id is what we group by
          // $dateToString converts Date to "YYYY-MM-DD" string
          _id: {
            $dateToString: {
              format: '%Y-%m-%d',
              date: '$createdAt'
            }
          },
          // count: for each group, count the documents
          count: { $sum: 1 }
        }
      },

      // STAGE 3: $sort — sort by date ascending
      {
        $sort: { _id: 1 }
      },

      // STAGE 4: $project — reshape output (like SELECT in SQL)
      // Rename _id to "date" for cleaner output
      {
        $project: {
          _id: 0,         // Remove the _id field
          date: '$_id',   // Rename _id → date
          count: 1        // Keep count
        }
      }

    ]);

    return res.status(200).json({ shortCode: code, data: dailyData });

  } catch (error) {
    console.error('Daily analytics error:', error);
    return res.status(500).json({ error: 'Server error' });
  }
};

// ─────────────────────────────────────────────────────────
// GET /api/analytics/:code/countries
// Returns top 10 countries by click count
// ─────────────────────────────────────────────────────────
const getCountryAnalytics = async (req, res) => {
  const { code } = req.params;

  try {
    const countryData = await Analytics.aggregate([
      
      // Filter by shortCode
      { $match: { shortCode: code } },

      // Group by country, count clicks
      {
        $group: {
          _id: '$country',
          count: { $sum: 1 }
        }
      },

      // Sort by count (highest first)
      { $sort: { count: -1 } },

      // Only return top 10 countries
      { $limit: 10 },

      // Clean up output
      {
        $project: {
          _id: 0,
          country: '$_id',
          count: 1
        }
      }
    ]);

    return res.status(200).json({ shortCode: code, data: countryData });

  } catch (error) {
    return res.status(500).json({ error: 'Server error' });
  }
};

// ─────────────────────────────────────────────────────────
// GET /api/analytics/:code/devices
// Returns device breakdown: mobile/tablet/desktop
// ─────────────────────────────────────────────────────────
const getDeviceAnalytics = async (req, res) => {
  const { code } = req.params;

  try {
    const deviceData = await Analytics.aggregate([
      { $match: { shortCode: code } },
      {
        $group: {
          _id: '$device',
          count: { $sum: 1 }
        }
      },
      { $sort: { count: -1 } },
      {
        $project: {
          _id: 0,
          device: '$_id',
          count: 1
        }
      }
    ]);

    return res.status(200).json({ shortCode: code, data: deviceData });

  } catch (error) {
    return res.status(500).json({ error: 'Server error' });
  }
};

// ─────────────────────────────────────────────────────────
// GET /api/analytics/:code/referrers
// Returns where clicks are coming from
// ─────────────────────────────────────────────────────────
const getReferrerAnalytics = async (req, res) => {
  const { code } = req.params;

  try {
    const referrerData = await Analytics.aggregate([
      { $match: { shortCode: code } },
      {
        $group: {
          _id: '$referrer',
          count: { $sum: 1 }
        }
      },
      { $sort: { count: -1 } },
      { $limit: 10 },
      {
        $project: {
          _id: 0,
          referrer: '$_id',
          count: 1
        }
      }
    ]);

    return res.status(200).json({ shortCode: code, data: referrerData });

  } catch (error) {
    return res.status(500).json({ error: 'Server error' });
  }
};

module.exports = {
  getAnalyticsSummary,
  getDailyAnalytics,
  getCountryAnalytics,
  getDeviceAnalytics,
  getReferrerAnalytics,
};
```

---

## Step 2: Analytics Routes

Create `server/routes/analytics.routes.js`:

```javascript
// server/routes/analytics.routes.js

const express = require('express');
const router = express.Router();
const {
  getAnalyticsSummary,
  getDailyAnalytics,
  getCountryAnalytics,
  getDeviceAnalytics,
  getReferrerAnalytics,
} = require('../controllers/analytics.controller');

router.get('/:code', getAnalyticsSummary);
router.get('/:code/daily', getDailyAnalytics);
router.get('/:code/countries', getCountryAnalytics);
router.get('/:code/devices', getDeviceAnalytics);
router.get('/:code/referrers', getReferrerAnalytics);

module.exports = router;
```

---

## Step 3: Add Analytics Routes to index.js

Update `server/index.js`:

```javascript
// Add this import
const analyticsRoutes = require('./routes/analytics.routes');

// Add this line after urlRoutes
app.use('/api/analytics', analyticsRoutes);
```

---

## Test Analytics

```
Method: GET
URL: http://localhost:5000/api/analytics/aB3xYz
URL: http://localhost:5000/api/analytics/aB3xYz/daily
URL: http://localhost:5000/api/analytics/aB3xYz/countries
URL: http://localhost:5000/api/analytics/aB3xYz/devices
```


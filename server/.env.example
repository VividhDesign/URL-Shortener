# ─── Server Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/urlshortener

# Redis connection string
# Local:   redis://localhost:6379
# Upstash: rediss://<user>:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# Your deployed Vercel frontend URL (no trailing slash)
# Example: https://snaplink.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Port (Render sets this automatically)
PORT=5000
